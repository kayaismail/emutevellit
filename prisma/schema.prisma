generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid())
  username String @unique
  password String
}

model Post {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  publishedAt DateTime @default(now())
  category    String
  imageUrl    String?
  youtubeUrl  String?
  excerpt     String
  content     String
}
